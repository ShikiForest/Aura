pub fn main() {
    Console.WriteLine("========================================")
    Console.WriteLine("  Aura Hard Test — DS / Sort / Graph")
    Console.WriteLine("========================================")

    test_data_structures()
    test_stack()
    test_queue()
    test_bubble_sort()
    test_selection_sort()
    test_merge_sort()
    test_graph_dfs_bfs()
    test_combined()

    Console.WriteLine("")
    Console.WriteLine("========================================")
    Console.WriteLine("  全テスト完了")
    Console.WriteLine("========================================")
}
