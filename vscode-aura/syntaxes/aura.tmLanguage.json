{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Aura",
  "scopeName": "source.aura",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#attributes" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#function-declaration" },
    { "include": "#type-declaration" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.aura",
          "match": "///.*$"
        },
        {
          "name": "comment.line.double-slash.aura",
          "match": "//.*$"
        },
        {
          "name": "comment.block.aura",
          "begin": "/\\*",
          "end": "\\*/",
          "captures": {
            "0": { "name": "punctuation.definition.comment.aura" }
          }
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.interpolated.aura",
          "begin": "\\$\"",
          "end": "\"",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.aura" } },
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.aura" } },
          "patterns": [
            {
              "name": "meta.interpolation.aura",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": { "0": { "name": "punctuation.section.interpolation.begin.aura" } },
              "endCaptures": { "0": { "name": "punctuation.section.interpolation.end.aura" } },
              "patterns": [
                { "include": "source.aura" }
              ]
            },
            {
              "name": "constant.character.escape.aura",
              "match": "\\\\(?:[\"\\\\tbfnr']|u[0-9a-fA-F]{4}|\\{\\{|\\}\\})"
            }
          ]
        },
        {
          "name": "string.quoted.double.aura",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.aura" } },
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.aura" } },
          "patterns": [
            {
              "name": "constant.character.escape.aura",
              "match": "\\\\(?:[\"\\\\tbfnr']|u[0-9a-fA-F]{4})"
            }
          ]
        },
        {
          "name": "string.quoted.single.aura",
          "begin": "'",
          "end": "'",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.aura" } },
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.aura" } },
          "patterns": [
            {
              "name": "constant.character.escape.aura",
              "match": "\\\\(?:[\"\\\\tbfnr']|u[0-9a-fA-F]{4})"
            }
          ]
        }
      ]
    },

    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.aura",
          "begin": "\\[",
          "end": "\\]",
          "beginCaptures": { "0": { "name": "punctuation.definition.attribute.begin.aura" } },
          "endCaptures": { "0": { "name": "punctuation.definition.attribute.end.aura" } },
          "patterns": [
            {
              "name": "entity.other.attribute-name.aura",
              "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
            },
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#constants" }
          ]
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.aura",
          "match": "\\b\\d+\\.\\d*(?:[eE][+-]?\\d+)?\\b|\\b\\d+[eE][+-]?\\d+\\b|\\.\\d+(?:[eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.hex.aura",
          "match": "\\b0[xX][0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.integer.binary.aura",
          "match": "\\b0[bB][01_]+\\b"
        },
        {
          "name": "constant.numeric.integer.aura",
          "match": "\\b\\d[\\d_]*\\b"
        }
      ]
    },

    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.aura",
          "match": "\\btrue\\b"
        },
        {
          "name": "constant.language.boolean.false.aura",
          "match": "\\bfalse\\b"
        },
        {
          "name": "constant.language.null.aura",
          "match": "\\bnull\\b"
        }
      ]
    },

    "function-declaration": {
      "patterns": [
        {
          "match": "\\b(fn)\\s+(operator)\\s+([+\\-*/%=!<>]+)",
          "captures": {
            "1": { "name": "keyword.declaration.function.aura" },
            "2": { "name": "keyword.other.operator.aura" },
            "3": { "name": "entity.name.function.operator.aura" }
          }
        },
        {
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.function.aura" },
            "2": { "name": "entity.name.function.aura" }
          }
        }
      ]
    },

    "type-declaration": {
      "patterns": [
        {
          "match": "\\b(class|struct|trait|enum|window)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.type.aura" },
            "2": { "name": "entity.name.type.aura" }
          }
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.aura",
          "match": "\\b(?:fn|let|var|class|struct|trait|enum|window|namespace|import|property|operator)\\b"
        },
        {
          "name": "keyword.control.aura",
          "match": "\\b(?:if|else|for|in|while|return|break|continue|switch|case|default|when|try|catch|finally|throw|using|await)\\b"
        },
        {
          "name": "keyword.other.modifier.aura",
          "match": "\\b(?:pub|async|derivable|mut|where|op)\\b"
        },
        {
          "name": "keyword.operator.expression.aura",
          "match": "\\b(?:is|as|not|and|or|new|derivateof|windowof|serialize|deserialize)\\b"
        },
        {
          "name": "variable.language.aura",
          "match": "\\b(?:self|item)\\b"
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.aura",
          "match": "\\b(?:i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|decimal|bool|char|string|object|void|handle)\\b"
        },
        {
          "name": "entity.name.type.class.aura",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.aura",
          "match": "->|=>"
        },
        {
          "name": "keyword.operator.pipe.aura",
          "match": "\\|(?!\\|)"
        },
        {
          "name": "keyword.operator.guard.aura",
          "match": "~"
        },
        {
          "name": "keyword.operator.coalesce.aura",
          "match": "\\?\\?=?"
        },
        {
          "name": "keyword.operator.logical.aura",
          "match": "\\|\\||&&|!"
        },
        {
          "name": "keyword.operator.comparison.aura",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.aura",
          "match": "[+\\-*/%]=|="
        },
        {
          "name": "keyword.operator.arithmetic.aura",
          "match": "[+\\-*/%]"
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.aura",
          "match": "[;,]"
        },
        {
          "name": "punctuation.accessor.aura",
          "match": "\\."
        },
        {
          "name": "punctuation.definition.block.aura",
          "match": "[{}]"
        },
        {
          "name": "punctuation.definition.parameters.aura",
          "match": "[()]"
        },
        {
          "name": "punctuation.definition.bracket.aura",
          "match": "[\\[\\]]"
        }
      ]
    },

    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.aura",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
